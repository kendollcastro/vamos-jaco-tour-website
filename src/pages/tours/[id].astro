---
import Layout from "../../layouts/Layout.astro";
import { getAllTours, getTourById, type Tour } from "../../data/tours";
import { getTourSchema, getBreadcrumbSchema } from "../../lib/seo-schemas";
import TourCard from "../../components/TourCard";
import NewsletterSection from "../../components/NewsletterSection";
import BookingSidebar from "../../components/BookingSidebar";
import TourGallery from "../../components/TourGallery";
import TourAccordion from "../../components/TourAccordion";
import TranslatedText from "../../components/TranslatedText";
import TranslatedMarkdown from "../../components/TranslatedMarkdown";
import TourInfoList from "../../components/TourInfoList";
import { marked } from "marked";

export async function getStaticPaths() {
    const tours = await getAllTours();
    return tours.map((tour) => ({
        params: { id: tour.id },
        props: { tour },
    }));
}

interface Props {
    tour?: Tour;
}

// In SSR mode without `prerender=true`, getStaticPaths props might be ignored.
// We should fetch the tour from the URL param if Astro.props.tour is missing.
const { id } = Astro.params;
const tour = Astro.props.tour || (id ? await getTourById(id) : null);

if (!tour) {
    return Astro.redirect("/404");
}

// Fetch all tours for related tours filtering (Astro props from getStaticPaths are mostly for static building)
const allTours = await getAllTours();

// Related tours: same category, excluding current
const relatedTours = allTours
    .filter((t) => t.category === tour.category && t.id !== tour.id)
    .slice(0, 3);

// SEO schemas
const tourSchema = getTourSchema({
    name: tour.title.en,
    description: tour.description.en.substring(0, 200),
    image: tour.image_url,
    price: tour.price,
    duration: tour.duration,
    location: tour.location,
    url: `https://vamosjaco.com/tours/${tour.id}`,
    category: tour.category,
});

const breadcrumbs = getBreadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Tours", url: "/tours" },
    { name: tour.title.en, url: `/tours/${tour.id}` },
]);

const schemas = [tourSchema, breadcrumbs];

const leadDescription = {
    en: tour.description?.en ? tour.description.en.split("\n\n")[0] : "",
    es: tour.description?.es ? tour.description.es.split("\n\n")[0] : "",
};

const remainingDescription = {
    en: tour.description?.en ? tour.description.en.split("\n\n").slice(1).join("\n\n") : "",
    es: tour.description?.es ? tour.description.es.split("\n\n").slice(1).join("\n\n") : "",
};
---

<Layout
    title={tour.seo?.title || `${tour.title.en} | Vamos Jacó Tours`}
    description={tour.seo?.description || tour.description.en.substring(0, 160)}
    image={tour.seo?.image || tour.image_url}
    keywords={`${tour.title.en}, ${tour.category} tour Jacó, adventure tour Costa Rica, ${tour.location}`}
    jsonLd={schemas}
    preloadImage={tour.image_url}
>
    <main>
        <!-- Tour Hero -->
        <section
            class="relative h-[55vh] min-h-[450px] flex items-end overflow-hidden"
        >
            <div class="absolute inset-0 z-0 overflow-hidden bg-dark">
                <img
                    src={tour.image_url}
                    alt={tour.title.en}
                    class="w-full h-full object-cover animate-ken-burns origin-center"
                    fetchpriority="high"
                    decoding="sync"
                />
                <div
                    class="absolute inset-0 bg-gradient-to-t from-dark via-dark/50 to-dark/20"
                >
                </div>
                <div
                    class="absolute inset-0 bg-gradient-to-r from-dark/30 via-transparent to-dark/30"
                >
                </div>
            </div>

            <!-- Glowing Orbs -->
            <div
                class="absolute inset-0 z-[1] pointer-events-none overflow-hidden"
            >
                <div
                    class="absolute bottom-0 left-1/4 w-80 h-80 bg-primary/8 rounded-full blur-[120px] animate-pulse"
                >
                </div>
                <div
                    class="absolute top-1/3 right-0 w-72 h-72 bg-brand-teal/8 rounded-full blur-[100px] animate-pulse"
                    style="animation-delay: 2s;"
                >
                </div>
            </div>

            <!-- Hero Content -->
            <div class="relative z-10 w-full max-w-7xl mx-auto px-6 pb-12">
                <div class="flex flex-wrap items-end justify-between gap-6">
                    <div>
                        <!-- Back Link -->
                        <a
                            href="/tours"
                            class="inline-flex items-center gap-2 text-white/60 hover:text-white text-sm font-medium mb-4 transition-colors"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M15 19l-7-7 7-7"></path>
                            </svg>
                            <TranslatedText client:load content={{ en: "Back to Tours", es: "Volver a los Tours" }} />
                        </a>

                        <!-- Badge -->
                        {
                            tour.badge && (
                                <div class="mb-3">
                                    <span
                                        class:list={[
                                            "px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider",
                                            tour.badge.color === "red" &&
                                                "bg-red-500 text-white",
                                            tour.badge.color === "yellow" &&
                                                "bg-yellow-400 text-gray-900",
                                            tour.badge.color === "green" &&
                                                "bg-green-500 text-white",
                                        ]}
                                    >
                                        {tour.badge.text}
                                    </span>
                                </div>
                            )
                        }

                        <!-- Title -->
                        <h1
                            class="text-4xl md:text-6xl font-black text-white uppercase tracking-tight italic drop-shadow-2xl leading-[0.95]"
                        >
                            <TranslatedText client:load content={tour.title} fallback={tour.title.en} />
                        </h1>

                        <!-- Meta -->
                        <div
                            class="flex flex-wrap items-center gap-4 mt-6 text-white/80 text-sm"
                        >
                            <div
                                class="flex items-center gap-1.5 bg-white/10 backdrop-blur-md px-4 py-2 rounded-xl border border-white/10"
                            >
                                <svg
                                    class="w-4 h-4 text-brand-orange"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                    ></path><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                    ></path>
                                </svg>
                                {tour.location}
                            </div>

                            <div
                                class="flex items-center gap-1.5 bg-white/10 backdrop-blur-md px-4 py-2 rounded-xl border border-white/10"
                            >
                                <svg
                                    class="w-4 h-4 text-brand-orange"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                    ></path>
                                </svg>
                                {tour.duration}
                            </div>
                        </div>
                    </div>

                    <!-- Price Badge -->
                    <div
                        class="bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-5 text-center min-w-[140px] shadow-2xl"
                    >
                        <p
                            class="text-xs text-white/80 font-medium mb-1 uppercase tracking-wider"
                        >
                            <TranslatedText client:load content={{en: "Starting From", es: "Desde"}} />
                        </p>
                        <p
                            class="text-4xl font-black text-white"
                            id="hero-price"
                        >
                            ${tour.price}
                        </p>
                        <p class="text-xs text-white/60 mt-1"><TranslatedText client:load content={{en: "per person", es: "por persona"}} /></p>
                    </div>
                </div>
            </div>

            <!-- Scroll Indicator -->
            <div
                class="absolute bottom-6 left-1/2 -translate-x-1/2 animate-bounce opacity-70 hidden md:flex flex-col items-center gap-2"
            >
                <span
                    class="text-[10px] uppercase tracking-[0.2em] text-white font-bold"
                    ><TranslatedText client:load content={{en: "Scroll", es: "Deslizar"}} /></span
                >
                <svg
                    class="w-4 h-4 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                </svg>
            </div>
        </section>

        <!-- Main Content -->
        <section class="relative py-16 md:py-20">
            <div class="max-w-7xl mx-auto px-6">
                <div class="flex flex-col lg:flex-row gap-12 justify-between">
                    <!-- Left: Tour Details -->
                    <div class="flex-1 space-y-12 min-w-0 md:max-w-3xl">
                        {/* Photo Gallery - Carousel Slider */}
                        {
                            tour.gallery && tour.gallery.length > 0 && (
                                <TourGallery
                                    client:only="react"
                                    images={tour.gallery}
                                    title={tour.title.en}
                                />
                            )
                        }

                        {/* Description & Accordion */}
                        <div class="mt-8 md:mt-12">
                            <h2
                                class="text-3xl font-black text-white mb-6 flex items-center gap-3 italic uppercase tracking-tight"
                            >
                                <span
                                    class="w-8 h-1 bg-gradient-to-r from-primary to-brand-orange rounded-full"
                                ></span>
                                <TranslatedText client:load content={{en: "About This Tour", es: "Acerca de este Tour"}} />
                            </h2>

                            <div class="space-y-8">
                                {/* Lead Paragraph */}
                                <TranslatedMarkdown
                                    client:load
                                    content={leadDescription}
                                    className="text-gray-300 text-lg md:text-xl leading-[1.8] font-light [&>p]:mb-6 last:[&>p]:mb-0 [&_strong]:text-white [&_strong]:font-semibold [&>ul]:list-disc [&>ul]:pl-5 [&>ul]:mb-6 [&>ul>li]:mb-3 [&>ul>li::marker]:text-brand-orange [&>ol]:list-decimal [&>ol]:pl-5 [&>ol]:mb-6 [&>ol>li]:mb-3 [&>h3]:text-xl [&>h3]:font-bold [&>h3]:text-white [&>h3]:mb-4 [&>h3]:mt-8 first:[&>h3]:mt-0"
                                />

                                {
                                    /* Accordion for the rest of the content (if any) */
                                }
                                {
                                    tour.description.en.split("\n\n").length >
                                        1 && (
                                        <TourAccordion
                                            client:load
                                            items={[
                                                {
                                                    id: "details",
                                                    title: {en: "The Experience", es: "La Experiencia"},
                                                    content: remainingDescription,
                                                    iconName: "info",
                                                },
                                            ]}
                                        />
                                    )
                                }
                            </div>
                        </div>

                        <!-- Highlights -->
                        <TourInfoList client:load type="highlights" data={tour.highlights} />

                        <!-- What's Included -->
                        <TourInfoList client:load type="includes" data={tour.includes} />
                    </div>

                    <!-- Right: Pricing Sidebar -->
                    <div
                        class="w-full lg:w-[380px] xl:w-[420px] flex-shrink-0 border-t lg:border-t-0 border-white/10 pt-10 lg:pt-0"
                    >
                        <div class="sticky top-28">
                            <BookingSidebar
                                client:load
                                tourId={tour.id}
                                tourTitle={tour.title.en}
                                price={tour.price}
                                durationOptions={tour.pricing_options}
                            />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Related Tours -->
        {
            relatedTours.length > 0 && (
                <section class="py-16 md:py-20 relative overflow-hidden border-t border-white/5">
                    <div class="absolute top-0 right-1/4 w-80 h-80 bg-primary/5 rounded-full blur-[120px] pointer-events-none" />
                    <div class="max-w-7xl mx-auto px-6">
                        <div class="text-center mb-12">
                            <span class="text-primary font-bold text-sm tracking-[0.2em] uppercase">
                                <TranslatedText client:load content={{en: "More Adventures", es: "Más Aventuras"}} />
                            </span>
                            <h2 class="text-3xl md:text-4xl font-black text-white uppercase tracking-tight italic mt-2">
                                <TranslatedText client:load content={{en: "Similar", es: "Tours"}} />{" "}
                                <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-brand-orange">
                                    <TranslatedText client:load content={{en: "Tours", es: "Similares"}} />
                                </span>
                            </h2>
                        </div>
                        <div class="flex flex-wrap justify-center gap-8">
                            {relatedTours.map((t) => (
                                <a
                                    href={`/tours/${t.id}`}
                                    class="block hover:scale-[1.03] transition-all duration-300 hover:shadow-[0_0_30px_rgba(242,127,27,0.15)] rounded-[25px]"
                                >
                                    <TourCard
                                        client:visible
                                        id={t.id}
                                        title={t.title}
                                        price={t.price}
                                        originalPrice={t.originalPrice}
                                        image_url={t.image_url}
                                        location={t.location}
                                        duration={t.duration}
                                        badge={t.badge}
                                    />
                                </a>
                            ))}
                        </div>
                    </div>
                </section>
            )
        }

        <!-- Newsletter -->
        <NewsletterSection client:visible />
    </main>
</Layout>

<script>
    import { bookingStore } from "../../store/booking";

    // Update Hero Price when booking options change
    const heroPriceEl = document.getElementById("hero-price");

    if (heroPriceEl) {
        bookingStore.subscribe((state) => {
            if (state.totalPrice > 0) {
                // If guests > 1, show total, otherwise show per person price (which is effectively total for 1)
                // Actually, let's just show the base price per adult for the selected duration in the hero,
                // or the total? Usually Hero "Starting From" implies per person base.
                // But if they change duration, the "base" changes.
                // Let's show the pricePerAdult corresponding to the selected duration.

                heroPriceEl.textContent = `$${state.pricePerAdult}`;
            }
        });
    }
</script>
