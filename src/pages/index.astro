---
import Layout from "../layouts/Layout.astro";
import HeroSlider from "../components/HeroSlider";
import TrustBar from "../components/TrustBar";
import AboutSection from "../components/AboutSection";
import PopularActivities from "../components/PopularActivities";
import ServicesBanner from "../components/ServicesBanner";
import TourGrid from "../components/TourGrid";
import TeamSection from "../components/TeamSection";
import TestimonialsSection from "../components/TestimonialsSection";
import TravelInspirations from "../components/TravelInspirations";
import FaqSection from "../components/FaqSection";
import NewsletterSection from "../components/NewsletterSection";
import ScrollReveal from "../components/ScrollReveal";
---

<Layout title="Vamos Jacó Tours | Costa Rica Adventures">
	<main>
		{/* Hero Section */}
		<HeroSlider client:only="react" />

		{/* Trust Bar */}
		<TrustBar client:visible />

		{/* Popular Activities — Fade Up */}
		<ScrollReveal client:visible animation="fade-up">
			<PopularActivities client:visible />
		</ScrollReveal>

		{/* Services Banner — Scale In */}
		<ScrollReveal client:visible animation="scale-in" delay={100}>
			<ServicesBanner client:visible />
		</ScrollReveal>

		{/* Featured Tours Section */}
		<section class="py-24 px-6 md:px-12 lg:px-20 relative overflow-hidden">
			{/* Glowing Orbs */}
			<div
				class="absolute top-20 -left-20 w-96 h-96 bg-primary/8 rounded-full blur-[150px] pointer-events-none"
			>
			</div>
			<div
				class="absolute bottom-20 -right-20 w-80 h-80 bg-brand-teal/8 rounded-full blur-[120px] pointer-events-none"
			>
			</div>

			<div class="max-w-7xl mx-auto relative z-10">
				<ScrollReveal client:visible animation="blur-in">
					<div class="text-center mb-16">
						<span
							class="inline-flex items-center gap-2 text-brand-orange font-bold uppercase tracking-[0.2em] text-sm mb-4"
						>
							🔥 Adrenaline Rush
						</span>
						<h2
							class="text-4xl md:text-6xl lg:text-7xl font-black text-white mb-6 uppercase tracking-tight"
						>
							Popular{" "}
							<span
								class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-brand-orange to-brand-yellow italic animate-gradient-text"
							>
								Adventures
							</span>
						</h2>
						<p class="text-gray-400 max-w-2xl mx-auto text-lg">
							Discover the most sought-after adrenaline
							experiences in Jacó and surrounding areas.
						</p>
					</div>
				</ScrollReveal>

				<ScrollReveal client:visible animation="fade-up" delay={200}>
					<TourGrid client:visible />
				</ScrollReveal>

				<ScrollReveal client:visible animation="fade-up" delay={300}>
					<div class="mt-14 text-center">
						<a
							href="/tours"
							class="inline-flex items-center gap-3 text-white bg-gradient-to-r from-primary to-brand-orange hover:shadow-[0_0_30px_rgba(220,53,34,0.4)] px-10 py-4 rounded-full font-bold text-lg transition-all duration-300 hover:scale-105 animate-pulse-glow"
						>
							View All Adventures <span class="text-xl">→</span>
						</a>
					</div>
				</ScrollReveal>
			</div>
		</section>

		{/* About / Welcome Section */}
		<ScrollReveal client:visible animation="fade-left">
			<AboutSection client:visible />
		</ScrollReveal>

		{/* Travel Inspirations Section */}
		<ScrollReveal client:visible animation="fade-right">
			<TravelInspirations client:visible />
		</ScrollReveal>

		{/* Team Section */}
		<ScrollReveal client:visible animation="fade-up">
			<TeamSection client:visible />
		</ScrollReveal>

		{/* Testimonials Section */}
		<ScrollReveal client:visible animation="scale-in">
			<TestimonialsSection client:visible />
		</ScrollReveal>

		{/* FAQ Section */}
		<ScrollReveal client:visible animation="blur-in">
			<FaqSection client:visible />
		</ScrollReveal>

		{/* Newsletter Section */}
		<ScrollReveal client:visible animation="fade-up">
			<NewsletterSection client:visible />
		</ScrollReveal>
	</main>
</Layout>
