---
import Layout from "../layouts/Layout.astro";
import AboutSection from "../components/AboutSection";
import TeamSection from "../components/TeamSection";
import TrustBar from "../components/TrustBar";
import AboutGallery from "../components/AboutGallery";
import NewsletterSection from "../components/NewsletterSection";
import FaqSection from "../components/FaqSection";
import ScrollReveal from "../components/ScrollReveal";
import { fetchWPAPI } from "../lib/wp";
import { getTeamMembers } from "../lib/supabase-team";
import {
    getOrganizationSchema,
    getBreadcrumbSchema,
    getFAQSchema,
} from "../lib/seo-schemas";

// Hero Image - Costa Rica jungle themed
const HERO_IMAGE = "/images/Flyboard/flyboard-vamos-jaco-tours-004.jpg";

// Fetch Team Members from Supabase
let teamMembers: any[] = [];
try {
    const members = await getTeamMembers();
    if (members && members.length > 0) {
        teamMembers = members.map((m) => ({
            id: m.id,
            name: m.name,
            position: m.position_en || "Team Member",
            position_en: m.position_en || undefined,
            position_es: m.position_es || undefined,
            image:
                m.image_url ||
                "https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=2574&auto=format&fit=crop",
            social: {
                instagram: m.social_instagram || undefined,
                linkedin: m.social_linkedin || undefined,
                twitter: m.social_twitter || undefined,
            },
        }));
    }
} catch (e) {
    console.error("Failed to load Team Members:", e);
}

// Fetch FAQs
let wpFaqs: any[] = [];
try {
    const rawFaqs = await fetchWPAPI("faq");
    if (rawFaqs && Array.isArray(rawFaqs)) {
        wpFaqs = rawFaqs.map((f: any) => ({
            question: f.title.rendered,
            // Remove the <p> tags from the excerpt
            answer: f.excerpt.rendered.replace(/<\/?p>/g, "").trim(),
        }));
    }
} catch (e) {
    console.error("Failed to load WP FAQs:", e);
}

const schemas = [
    getOrganizationSchema(),
    getBreadcrumbSchema([
        { name: "Home", url: "/" },
        { name: "About Us", url: "/about" },
    ]),
    ...(wpFaqs.length > 0 ? [getFAQSchema(wpFaqs)] : []),
].filter(Boolean);
---

<Layout
    title="About Us | Vamos Jacó Tours — Local Adventure Experts"
    description="Meet the Vamos Jacó Tours team. Local guides passionate about sharing the best adventures in Costa Rica — from ATV rides through the jungle to ocean experiences. Family-owned since 2018."
    keywords="about Vamos Jacó, Costa Rica tour guides, Jacó local guides, adventure tour company, Costa Rica travel agency"
    jsonLd={schemas}
>
    {/* Page Hero */}
    <section
        class="relative h-[60vh] min-h-[450px] flex items-center justify-center overflow-hidden"
    >
        <div class="absolute inset-0">
            <img
                src={HERO_IMAGE}
                alt="Costa Rica Rainforest"
                class="w-full h-full object-cover opacity-60"
            />
            <div
                class="absolute inset-0 bg-gradient-to-b from-dark/30 via-dark/60 to-dark"
            >
            </div>
        </div>
        <div
            class="relative z-10 text-center px-6 max-w-5xl mx-auto animate-zoom-in"
        >
            <span
                class="inline-block bg-brand-teal/20 backdrop-blur-sm border border-brand-teal/30 text-brand-teal px-4 py-1 rounded-full text-sm font-bold tracking-widest uppercase mb-6"
                >Our Story</span
            >
            <h1
                class="text-5xl md:text-8xl font-black text-white mb-6 uppercase tracking-tighter drop-shadow-2xl"
            >
                Passion for
                <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-brand-teal via-brand-orange to-brand-yellow animate-gradient-text"
                >
                    Adventure
                </span>
            </h1>
            <p
                class="text-xl md:text-2xl text-gray-200 font-bold max-w-3xl mx-auto tracking-wide"
            >
                We are more than a tour agency. We are your local friends
                showing you the hidden gems of Jacó.
            </p>
        </div>
    </section>

    <main class="relative">
        {/* Background Blobs */}
        <div
            class="absolute top-0 right-0 w-1/3 h-1/3 bg-brand-teal/10 blur-[100px] rounded-full pointer-events-none"
        >
        </div>
        <div
            class="absolute bottom-1/3 left-0 w-1/3 h-1/3 bg-primary/10 blur-[100px] rounded-full pointer-events-none"
        >
        </div>

        {/* Main Info & Stats */}
        <ScrollReveal client:visible animation="fade-up">
            <AboutSection client:visible />
        </ScrollReveal>

        {/* Team Carousel */}
        <ScrollReveal client:visible animation="fade-left">
            <TeamSection client:visible members={teamMembers} />
        </ScrollReveal>

        {/* Gallery "Moments" */}
        <ScrollReveal client:visible animation="scale-in" delay={100}>
            <AboutGallery client:visible />
        </ScrollReveal>

        {/* Trust/Partners */}
        <ScrollReveal client:visible animation="blur-in">
            <TrustBar client:visible />
        </ScrollReveal>

        {/* FAQ Section */}
        <ScrollReveal client:visible animation="blur-in">
            <FaqSection client:visible />
        </ScrollReveal>

        {/* Newsletter CTA */}
        <ScrollReveal client:visible animation="fade-up" delay={200}>
            <NewsletterSection client:visible />
        </ScrollReveal>
    </main>
</Layout>
